# ─────────────────────────────────────────────────────
#  CLOUD COMPUTING LLJ — Environment Config Example
#  Copy this to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────

# ── Kafka (KRaft mode — no Zookeeper) ────────────────
KAFKA_BROKER=kafka:29092
KAFKA_EXTERNAL_PORT=9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qg
KAFKA_UI_PORT=8080

# ── Spark ─────────────────────────────────────────────
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=9090
SPARK_WORKER_MEMORY=4g
SPARK_WORKER_CORES=2
SPARK_EXECUTOR_MEMORY=3g

# ── MongoDB ───────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo
MONGO_PORT=27017
MONGO_DB=llj_cvs

# ── PostgreSQL ────────────────────────────────────────
POSTGRES_USER=llj_user
POSTGRES_PASSWORD=change_me_pg
POSTGRES_DB=llj_gold
POSTGRES_PORT=5432

# ── MinIO (S3-compatible Data Lake) ──────────────────
MINIO_ROOT_USER=llj_minio_admin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Bucket names ──────────────────────────────────────
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold
